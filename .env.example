# PostgreSQL connection string for the Prisma setup in M1-T02.
DATABASE_URL="postgresql://user:password@localhost:5432/karaoke_number_finder?schema=public"

# Public app metadata.
NEXT_PUBLIC_APP_NAME="KaraokeNumberFinder"

# Operational contact used by later report/support flows.
SUPPORT_EMAIL="support@example.com"

# M3 Google OAuth / Better Auth server configuration.
# Generate a unique value of at least 32 characters; never commit a real secret.
BETTER_AUTH_SECRET="replace-with-a-random-secret-of-at-least-32-characters"

# Exact application origin. Production must use HTTPS.
BETTER_AUTH_URL="http://localhost:3000"
AUTH_TRUSTED_ORIGIN="http://localhost:3000"

# Google OAuth Web application credentials. Do not add extra scopes or offline access.
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"

# Must exactly equal BETTER_AUTH_URL + /api/auth/callback/google.
GOOGLE_OAUTH_CALLBACK_URL="http://localhost:3000/api/auth/callback/google"
