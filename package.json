    "better-auth": "1.6.23",
    "dotenv": "^17.4.2",
    "next": "^16.2.9",
    "pg": "^8.22.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "server-only": "^0.0.1"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "^8.5.16"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.30.0",
    "eslint-config-next": "^16.2.9",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.2",
    "prisma": "^7.8.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
