    "pretest": "npm run db:generate",
    "test": "vitest run",
    "test:e2e": "vite-node scripts/e2e/run.ts",
    "test:e2e:repeat": "vite-node scripts/e2e/run.ts --repeat-each=2",
    "e2e:serve": "vite-node scripts/e2e/serve.ts",
    "test:m3-db": "vite-node scripts/m3/test-db.ts",
    "seed:validate": "vite-node scripts/seed/validate.ts",
    "seed:import": "vite-node scripts/seed/import.ts",
    "seed:search-smoke": "vite-node scripts/seed/search-smoke.ts",
    "seed:add-song": "vite-node scripts/seed/add-song.ts",
    "seed:add-alias": "vite-node scripts/seed/add-alias.ts",
    "seed:add-entry": "vite-node scripts/seed/add-entry.ts",
    "perf:baseline": "vite-node scripts/perf/baseline.ts",
    "perf:dataset-generate": "vite-node scripts/perf/generate-synthetic-dataset.ts",
    "perf:dataset-import": "vite-node scripts/perf/import-synthetic-dataset.ts",
    "perf:dataset-validate": "vite-node scripts/perf/validate-synthetic-dataset.ts",
    "perf:explain": "vite-node scripts/perf/explain.ts",
    "perf:query-shape": "vite-node scripts/perf/query-shape.ts",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "1.6.23",
    "@prisma/adapter-pg": "^7.8.0",
